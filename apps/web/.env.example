# Which model backend to use: openai | anthropic | ollama.
# If unset, Clarity auto-detects from whichever key below is present.
MODEL_PROVIDER=

# Cloud, bring-your-own-key (per-run cost is cents, on your own bill):
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Local, zero API cost (the keyless path). Known-good small models:
# qwen3:4b (default) · llama3.2:3b · phi4-mini:3.8b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:4b

# Run budget (server-side clamped to <=20 fetches / <=120000 ms).
# The wall clock bounds fetching only — synthesis is governed by your cancel
# button plus the model inactivity watchdog below (PLAN.md decision 15).
CLARITY_MAX_FETCHES=12
CLARITY_DEADLINE_MS=60000
CLARITY_MODEL_INACTIVITY_MS=300000

# Optional: GitHub fine-grained PAT for the resume-profile importer (public repos, read-only).
# Keyless works at 60 requests/hour; a token raises it to 5,000 and enables pinned-repo ordering.
GITHUB_TOKEN=

# Optional: absolute path to the Tectonic binary for PDF compile (increment 15).
# Leave blank to auto-detect on PATH. Without Tectonic the .tex download still works;
# install via Scoop / Homebrew / pacman or conda / the GitHub release (never winget or Chocolatey).
TECTONIC_PATH=
