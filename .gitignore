# dependencies
node_modules/

# next.js
.next/
out/
next-env.d.ts
*.tsbuildinfo

# local cache — a user's job-search activity never leaves their machine,
# and it never enters version control either. The second, root-anchored
# pattern is a safety net: PAGE_CACHE_DIR is cwd-relative, so a server
# launched from the repo root (instead of apps/web) would drop page
# snapshots at ./data — that mistake must not become a commit.
apps/web/data/
/data/

# env
.env
.env.local
.env*.local

# test output
coverage/

# os
.DS_Store
Thumbs.db

# internal documentation — the public repo publishes only the README. These are
# kept locally (removed from tracking with `git rm --cached`) but never pushed:
# the product spec, agent working notes, and everything under docs/ (build
# plans, architecture notes, and the design reference).
/clarity-v1-spec.md
/CLAUDE.md
/docs/
